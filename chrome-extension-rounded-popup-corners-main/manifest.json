{
  "manifest_version": 3,
  "name": "Type Tuner",
  "version": "1.0",
  "description": "This extension allows you to change the font of web pages to your preferred style.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "128": "images/icon-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
} 